<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="220dp"
    android:layout_height="wrap_content"
    android:background="@drawable/compose_audio_record_dialog_background"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="16dp">

    <com.moez.QKSMS.common.widget.QkTextView
        android:id="@+id/audioRecordActionButton"
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:background="@drawable/compose_audio_record_button_background"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:gravity="center"
        android:paddingBottom="2dp"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold" />

    <com.moez.QKSMS.common.widget.QkTextView
        android:id="@+id/audioRecordStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:textColor="@color/textSecondary"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
